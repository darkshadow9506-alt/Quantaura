# ============================================================
#  QuantAura — environment variables
#  Copy this file to ".env" and fill in your own values.
#  NEVER commit your real .env (it is in .gitignore).
# ============================================================

# --- Telegram (required to run the bot) -----------------------------
# 1. Open Telegram, talk to @BotFather, send /newbot, follow the steps.
# 2. BotFather gives you a token like 123456789:ABCdEf...  -> paste below.
TELEGRAM_BOT_TOKEN=

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone. Get your id from @userinfobot.
TELEGRAM_ALLOWED_USERS=

# Optional: a chat id the scheduler will push scans to automatically.
# Leave empty to disable scheduled broadcasts.
TELEGRAM_BROADCAST_CHAT_ID=

# --- Account / risk (used only to size positions in signals) --------
# Your notional account size in the quote currency (USD). Purely for
# position-size suggestions; the bot never touches your money.
ACCOUNT_EQUITY=10000

# --- Crypto data source (optional) ----------------------------------
# ccxt exchange id used for crypto OHLCV. Default "toobit".
# Any ccxt-supported id works (e.g. toobit, bybit, bitget, kucoin).
CCXT_EXCHANGE=toobit
